{
  "name": "@ubermanu/prettier-config",
  "version": "3.4.1",
  "description": "A prettier config with preconfigured plugins",
  "keywords": [
    "prettier",
    "config"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ubermanu/prettier-config.git"
  },
  "license": "MIT",
  "author": "Emmanuel Vodor <emmanuel.vodor@proton.me>",
  "type": "commonjs",
  "main": "prettier.config.cjs",
  "files": [
    "prettier.config.cjs"
  ],
  "scripts": {
    "changeset": "changeset",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "postcss": "^8.4.29",
    "prettier-plugin-css-order": "^2.0.0",
    "prettier-plugin-jsdoc": "^1.0.1",
    "prettier-plugin-organize-imports": "^4.0.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "try-require": "^1.2.1",
    "typescript": "^6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.1",
    "@types/node": "^22",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3"
  },
  "peerDependencies": {
    "prettier": "^3",
    "prettier-plugin-svelte": "*",
    "prettier-plugin-tailwindcss": "*"
  },
  "peerDependenciesMeta": {
    "prettier-plugin-svelte": {
      "optional": true
    },
    "prettier-plugin-tailwindcss": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
